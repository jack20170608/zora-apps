# editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.md]
max_line_length = 0
trim_trailing_whitespace = false

[*.xml]
indent_size = 4
indent_style = space

[*.html]
indent_size = 2
indent_style = space

[*.css]
indent_size = 2
indent_style = space

[*.json]
indent_size = 2
indent_style = space
