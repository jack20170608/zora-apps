### Test: Very Long agentId (Boundary Test)
POST {{baseUrl}}/api/v1/scheduler/register
Content-Type: application/json
#Authorization: Basic {{username}} {{password}}

{
  "agentId": "agent-with-very-long-name-that-might-exceed-normal-limits-and-test-boundary-conditions-12345678901234567890",
  "name": "Boundary Test Agent",
  "agentUrl": "http://localhost:9098",
  "maxConcurrentTasks": 1,
  "maxPendingTasks": 2
}

> {%
client.test("Edge Case: Very Long agentId (Boundary Test)", function() {
