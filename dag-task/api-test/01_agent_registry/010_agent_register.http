### AgentRegistryApi HTTP Test Cases
### Base URL: http://localhost:8080
### All endpoints accept JSON and return JSON responses
@testAgent001="test-agent-001"
@testAgent002="test-agent-002"

### ============================================================
### 1. Agent Registration Endpoint
### POST /api/v1/scheduler/register
### ============================================================

### Test Case 1.1: Successful Agent Registration
POST {{baseUrl}}/api/v1/scheduler/register
Content-Type: application/json
##Authorization: Basic {{username}} {{password}}
Accept: application/json

{
  "agentId": "{{testAgent001}}",
  "name": "Test Agent 001",
  "agentUrl": "http://localhost:9091",
  "maxConcurrentTasks": 5,
  "maxPendingTasks": 10,
  "supportedExecutionKeys": ["shell", "python", "java"],
    "generateToken": true
}

> {%

    console.log("=== Response Details ===");
    console.log("Status Code:", response.status);
    console.log("Response Body:", JSON.stringify(response.body, null, 2));

client.test("Test Case 1.1: Successful Agent Registration", function() {
    client.assert(response.status === 200, "Response status should be 200");
    let json = response.body;
    client.assert(json.code === 200, "Response code should be 200");
    client.assert(json.message !== undefined && json.message !== "", "Response should have a message");
    client.assert(json.timestamp !== undefined && json.timestamp > 0, "Response should have a valid timestamp");
});
%}

