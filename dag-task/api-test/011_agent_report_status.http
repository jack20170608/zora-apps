### ============================================================
### 3. Performance and Load Testing Scenarios
### ============================================================

### Rapid Status Updates (Simulate High Frequency Heartbeats)
POST {{baseUrl}}/api/v1/scheduler/report_status
Content-Type: application/json
#Authorization: Basic {{username}} {{password}}

{
  "agentId": "load-test-agent",
  "running": true,
  "pendingTasks": 0,
  "runningTasks": 0,
  "finishedTasks": 1000,
  "maxConcurrentTasks": 10,
  "maxPendingTasks": 20
}

> {%
client.test("Performance: Rapid Status Updates", function() {
    client.assert(response.status === 200, "Response status should be 200");
    var json = response.body;
    client.assert(json.code === 200, "Response code should be 200");
    client.assert(json.message !== undefined && json.message !== "", "Response should have a message");
    client.assert(json.timestamp !== undefined && json.timestamp > 0, "Response should have a valid timestamp");
});
%}

### ============================================================
### Response Format Reference
### ============================================================

### Success Response (HTTP 200 OK):
### {
###   "code": 200,
###   "message": "Operation successful message",
###   "timestamp": 1714215600000,
###   "data": null
### }

### Error Response (HTTP 400 Bad Request):
### {
###   "code": 400,
###   "message": "Error description",
###   "timestamp": 1714215600000,
###   "data": null
### }

