### Agent Report Status HTTP Test Cases
### Base URL: http://localhost:8080
### All endpoints accept JSON and return JSON responses

### ============================================================
### 1. Agent Status Reporting Endpoint (Heartbeat)
### POST /api/v1/scheduler/report_status
### ============================================================

### Test Case 1.1: Report Agent Status - Running with Tasks
POST {{baseUrl}}/api/v1/scheduler/report_status
Content-Type: application/json
#Authorization: Basic {{username}} {{password}}

{
  "agentId": "agent-001",
  "running": true,
  "pendingTasks": 3,
  "runningTasks": 2,
  "finishedTasks": 15,
  "maxConcurrentTasks": 5,
  "maxPendingTasks": 10
}

> {%
client.test("Test Case 1.1: Report Agent Status - Running with Tasks", function() {
    client.assert(response.status === 200, "Response status should be 200");
    var json = response.body;
    client.assert(json.code === 200, "Response code should be 200");
    client.assert(json.message !== undefined && json.message !== "", "Response should have a message");
    client.assert(json.timestamp !== undefined && json.timestamp > 0, "Response should have a valid timestamp");
});
%}

