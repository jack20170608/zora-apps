### ============================================================
### 9. Final health check after all operations
### ============================================================

### Test Case 9.1: Verify final health status
GET {{agentBaseUrl}}/api/v1/agent/health

> {%
client.test("Test Case 9.1: Final health check", function() {
    client.assert(response.status === 200, "Response status should be 200");
    let json = response.body;
    client.assert(json.running === true, "Agent should still be running");
    client.assert(json.agentId !== undefined, "Response should have agentId");
    client.assert(json.pendingSize !== undefined, "Response should have pendingSize");
    client.assert(json.runningSize !== undefined, "Response should have runningSize");
});
%}

###

### Test Case 9.2: Final ping check
GET {{agentBaseUrl}}/api/v1/agent/ping

> {%
client.test("Test Case 9.2: Final ping check", function() {
    client.assert(response.status === 200, "Response status should be 200");
    client.assert(response.body === "pong", "Response body should still be 'pong'");
});
%}

### ============================================================
### Response Format Reference
### ============================================================

### Success Response (HTTP 200 OK):
### {
###   "success": true,
###   "message": "Operation completed"
### }

### Accepted Response (HTTP 202 Accepted - submit only):
### {
###   "success": true,
###   "message": "Task accepted",
###   "taskId": 1101,
###   "pendingPosition": 0
### }

### Error Response (HTTP 400 Bad Request):
### {
###   "error": "Error description"
### }

### Not Found Response (HTTP 404 Not Found):
### {
###   "error": "Task not found"
### }

### Too Many Requests Response (HTTP 429):
### {
###   "error": "Pending queue is full",
###   "capacity": 100,
###   "currentSize": 100
### }

### ============================================================
### End of Test Cases
### ============================================================
