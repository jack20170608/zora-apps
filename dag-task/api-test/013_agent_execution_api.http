

###

### Test Case 1.2: Submit a Python script task
POST {{agentBaseUrl}}/api/v1/agent/submit
Content-Type: application/json

{
  "taskId": 1102,
  "taskType": "PYTHON_SCRIPTS",
  "opsType": "SUBMIT",
  "priorityType": "HIGH",
  "executionClass": "python_script_runner",
  "input": "{\"script\": \"print('Hello from Python')\", \"timeout\": 30}",
  "dealer": "scheduler-001"
}

> {%
client.test("Test Case 1.2: Submit a Python script task", function() {
    client.assert(response.status === 202, "Response status should be 202 Accepted");
    let json = response.body;
    client.assert(json.success === true, "Response should indicate success");
    client.assert(json.taskId === 1102, "Response taskId should match submitted taskId");
});
%}

