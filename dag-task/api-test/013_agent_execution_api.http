### ============================================================
### 2. Health check after submissions
### ============================================================

### Test Case 2.1: Verify health reflects submitted tasks
GET {{agentBaseUrl}}/api/v1/agent/health

> {%
client.test("Test Case 2.1: Health reflects submitted tasks", function() {
    client.assert(response.status === 200, "Response status should be 200");
    let json = response.body;
    client.assert(json.running === true, "Agent should be running");
    client.assert(json.pendingSize >= 0, "Pending size should be non-negative");
    client.assert(json.runningSize >= 0, "Running size should be non-negative");
});
%}

