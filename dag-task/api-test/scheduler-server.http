# ============================================
# Test API for DAG Scheduler Server - Agent Registry API
# ============================================
# -----------------------------------------------------------------------------
# 1. Register a new agent with the scheduling center
# -----------------------------------------------------------------------------
### Register agent example - default-agent
POST {{baseUrl}}/api/v1/agent/register
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "agentId": "default-agent-101",
  "agentUrl": "http://localhost:9000/hahaha",
  "maxConcurrentTasks": 10,
  "maxPendingTasks": 100,
  "supportedExecutionKeys": ["shell", "python", "java", "docker"]
}

### Register another agent - python-worker
POST {{baseUrl}}/api/v1/agent/register
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "agentId": "python-worker-002",
  "agentUrl": "http://localhost:9001",
  "maxConcurrentTasks": 20,
  "maxPendingTasks": 200,
  "supportedExecutionKeys": ["python", "data-processing"]
}

### Register agent that only handles docker tasks
POST {{baseUrl}}/api/v1/agent/register
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "agentId": "docker-agent-003",
  "agentUrl": "http://localhost:9002",
  "maxConcurrentTasks": 5,
  "maxPendingTasks": 50,
  "supportedExecutionKeys": ["docker", "container"]
}

# -----------------------------------------------------------------------------
# 2. Report agent status (heartbeat)
# Agents call this periodically to report current queue statistics
# -----------------------------------------------------------------------------
### Report status for default-agent
POST {{baseUrl}}/api/v1/agent/status
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "agentId": "default-agent-001",
  "running": true,
  "pendingTasks": 2,
  "runningTasks": 3,
  "finishedTasks": 42
}

### Report status for python-worker
POST {{baseUrl}}/api/v1/agent/status
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "agentId": "python-worker-002",
  "running": true,
  "pendingTasks": 5,
  "runningTasks": 8,
  "finishedTasks": 128
}


# -----------------------------------------------------------------------------
# 3. Report task result after execution completes
# -----------------------------------------------------------------------------
### Report successful task result
POST {{baseUrl}}/api/v1/agent/task/result
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "agentId": "default-agent-001",
  "taskId": 1,
  "success": true,
  "outputJson": "{\"result\": \"Hello World\", \"durationMs\": 1234}",
  "endTime": "2024-01-15T10:30:00Z"
}

### Report failed task result
POST {{baseUrl}}/api/v1/agent/task/result
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "agentId": "python-worker-002",
  "taskId": 2,
  "success": false,
  "outputJson": "{\"errorMessage\": \"Timeout waiting for process exit\", \"durationMs\": 30000}",
  "endTime": "2024-01-15T11:00:00Z"
}

# -----------------------------------------------------------------------------
# 4. Unregister an agent when it's shutting down
# -----------------------------------------------------------------------------
### Unregister the docker agent
POST {{baseUrl}}/api/v1/agent/unregister
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "agentId": "docker-agent-003"
}

# -----------------------------------------------------------------------------
# 5. Health check - verify server is running
# -----------------------------------------------------------------------------
### get health info
GET {{baseUrl}}/actuator/health
Authorization: Basic {{username}} {{password}}
