        "taskId": 1002,
        "success": false,
        "output": "{\"error\": \"NullPointerException\", \"stackTrace\": \"at com.example.Task.execute(Task.java:42)\"}",
        "endTime": "2025-04-27T10:35:00Z"
    }
]

> {%
    client.test("Test Case 3.2: Report Single Failed Task Result", function() {
