### ============================================================
### 3. Task Result Reporting Endpoint
### POST /api/v1/scheduler/report_result
### ============================================================


### Test Case 3.1: Report Single Successful Task Result
POST {{baseUrl}}/api/v1/scheduler/report_result
Content-Type: application/json
#Authorization: Basic {{username}} {{password}}

[
    {
        "agentId": "agent-001",
        "taskId": 1001,
        "success": true,
        "output": "{\"result\": \"Task completed successfully\", \"data\": {\"processed\": 150, \"errors\": 0}}",
        "endTime": "2025-04-27T10:30:00Z"
    }
]

> {%
    client.test("Test Case 3.1: Report Single Successful Task Result", function() {
        client.assert(response.status === 200, "Response status should be 200");
        let json = response.body;
        client.assert(json.code === 200, "Response code should be 200");
        client.assert(json.message !== undefined && json.message !== "", "Response should have a message");
        client.assert(json.timestamp !== undefined && json.timestamp > 0, "Response should have a valid timestamp");
    });
%}

### Test Case 3.2: Report Single Failed Task Result
POST {{baseUrl}}/api/v1/scheduler/report_result
Content-Type: application/json
#Authorization: Basic {{username}} {{password}}

[
