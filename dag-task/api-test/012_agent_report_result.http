### ============================================================
### Performance and Load Testing Scenarios
### ============================================================

### Note: These tests are designed for load testing tools like k6 or JMeter
### Below are example requests that can be used as templates

### Bulk Task Results Report
POST {{baseUrl}}/api/v1/scheduler/report_result
Content-Type: application/json
#Authorization: Basic {{username}} {{password}}

[
    {
        "agentId": "load-test-agent",
        "taskId": 10001,
        "success": true,
        "output": "{\"batch\": 1, \"item\": 1}",
        "endTime": "2025-04-27T13:00:00Z"
    },
    {
        "agentId": "load-test-agent",
        "taskId": 10002,
        "success": true,
        "output": "{\"batch\": 1, \"item\": 2}",
        "endTime": "2025-04-27T13:00:01Z"
    },
    {
        "agentId": "load-test-agent",
        "taskId": 10003,
        "success": true,
        "output": "{\"batch\": 1, \"item\": 3}",
        "endTime": "2025-04-27T13:00:02Z"
    }
]

> {%
    client.test("Performance: Bulk Task Results Report", function() {
        client.assert(response.status === 200, "Response status should be 200");
        var json = response.body;
        client.assert(json.code === 200, "Response code should be 200");
        client.assert(json.message !== undefined && json.message !== "", "Response should have a message");
        client.assert(json.timestamp !== undefined && json.timestamp > 0, "Response should have a valid timestamp");
    });
%}
