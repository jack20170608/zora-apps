# ============================================
# Test API for DAG Scheduler Server - Task Template API
# ============================================
# After refactoring: simplified API with search endpoints
# ============================================
# -----------------------------------------------------------------------------
# 1. Create first template version - ETL data processing
# -----------------------------------------------------------------------------
### Create ETL data processing template v1.0.0 and set as active
POST {{baseUrl}}/api/v1/template?setActive=true
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKey": "etl-data-processing",
  "templateName": "ETL Data Processing Workflow",
  "description": "A general-purpose ETL workflow that extracts, transforms and loads data from source to destination",
  "version": "1.0.0",
  "dagDefinition": "{\n  \"nodes\": [\n    {\"id\": \"extract\", \"type\": \"extractor\", \"config\": {\"source\": \"${source}\"}},\n    {\"id\": \"transform\", \"type\": \"transformer\", \"config\": {\"rules\": \"${transformRules}\"}},\n    {\"id\": \"load\", \"type\": \"loader\", \"config\": {\"destination\": \"${destination}\"}}\n  ],\n  \"edges\": [\n    {\"from\": \"extract\", \"to\": \"transform\"},\n    {\"from\": \"transform\", \"to\": \"load\"}\n  ]\n}",
  "parameterSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"source\": {\"type\": \"string\", \"description\": \"Source connection string\"},\n    \"transformRules\": {\"type\": \"string\", \"description\": \"Transformation rules JSON\"},\n    \"destination\": {\"type\": \"string\", \"description\": \"Destination connection string\"}\n  },\n  \"required\": [\"source\", \"destination\"]\n}"
}

### Create daily backup template v1.0.0
POST {{baseUrl}}/api/v1/template?setActive=true
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKey": "daily-database-backup",
  "templateName": "Daily Database Backup",
  "description": "Backup database to remote storage and verify backup integrity",
  "version": "1.0.0",
  "dagDefinition": "{\n  \"nodes\": [\n    {\"id\": \"dump\", \"type\": \"database-dump\", \"config\": {\"database\": \"${databaseName}\"}},\n    {\"id\": \"compress\", \"type\": \"gzip-compress\"},\n    {\"id\": \"upload\", \"type\": \"s3-upload\", \"config\": {\"bucket\": \"${backupBucket}\"}},\n    {\"id\": \"verify\", \"type\": \"backup-verify\"}\n  ],\n  \"edges\": [\n    {\"from\": \"dump\", \"to\": \"compress\"},\n    {\"from\": \"compress\", \"to\": \"upload\"},\n    {\"from\": \"upload\", \"to\": \"verify\"}\n  ]\n}",
  "parameterSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"databaseName\": {\"type\": \"string\", \"description\": \"Database name to backup\"},\n    \"backupBucket\": {\"type\": \"string\", \"description\": \"S3 bucket name for backup\"},\n    \"retentionDays\": {\"type\": \"integer\", \"description\": \"Number of days to keep backup\"}\n  },\n  \"required\": [\"databaseName\", \"backupBucket\"]\n}"
}

### Create ML model training template v1.0.0
POST {{baseUrl}}/api/v1/template?setActive=true
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKey": "ml-model-training",
  "templateName": "ML Model Training Pipeline",
  "description": "End-to-end machine learning model training with data validation and model evaluation",
  "version": "1.0.0",
  "dagDefinition": "{\n  \"nodes\": [\n    {\"id\": \"fetch-data\", \"type\": \"data-fetcher\"},\n    {\"id\": \"validate\", \"type\": \"data-validator\"},\n    {\"id\": \"preprocess\", \"type\": \"data-preprocessor\"},\n    {\"id\": \"train\", \"type\": \"model-trainer\"},\n    {\"id\": \"evaluate\", \"type\": \"model-evaluator\"},\n    {\"id\": \"deploy\", \"type\": \"model-deployer\", \"condition\": \"${autoDeploy}\"\n  }\n  ],\n  \"edges\": [\n    {\"from\": \"fetch-data\", \"to\": \"validate\"},\n    {\"from\": \"validate\", \"to\": \"preprocess\"},\n    {\"from\": \"preprocess\", \"to\": \"train\"},\n    {\"from\": \"train\", \"to\": \"evaluate\"},\n    {\"from\": \"evaluate\", \"to\": \"deploy\"}\n  ]\n}"
}

###
# -----------------------------------------------------------------------------
# 2. Create a new version of existing template
# -----------------------------------------------------------------------------
### Create ETL template v1.1.0 with improved error handling (don't set as active yet)
POST {{baseUrl}}/api/v1/template?setActive=false
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKey": "etl-data-processing",
  "templateName": "ETL Data Processing Workflow",
  "description": "A general-purpose ETL workflow that extracts, transforms and loads data from source to destination (with improved error handling)",
  "version": "1.1.0",
  "active": false,
  "dagDefinition": "{\n  \"nodes\": [\n    {\"id\": \"extract\", \"type\": \"extractor\", \"config\": {\"source\": \"${source}\", \"retryCount\": 3}},\n    {\"id\": \"transform\", \"type\": \"transformer\", \"config\": {\"rules\": \"${transformRules}\", \"errorTolerance\": 0.05}},\n    {\"id\": \"load\", \"type\": \"loader\", \"config\": {\"destination\": \"${destination}\", \"atomicWrite\": true}}\n  ],\n  \"edges\": [\n    {\"from\": \"extract\", \"to\": \"transform\"},\n    {\"from\": \"transform\", \"to\": \"load\"}\n  ]\n}",
  "parameterSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"source\": {\"type\": \"string\", \"description\": \"Source connection string\"},\n    \"transformRules\": {\"type\": \"string\", \"description\": \"Transformation rules JSON\"},\n    \"destination\": {\"type\": \"string\", \"description\": \"Destination connection string\"},\n    \"errorTolerance\": {\"type\": \"number\", \"description\": \"Allowed error rate 0.0-1.0\", \"default\": 0.0}\n  },\n  \"required\": [\"source\", \"destination\"]\n}"
}

###
# -----------------------------------------------------------------------------
# 3. Search templates - different search criteria examples
# -----------------------------------------------------------------------------
### Search all active templates (find all where active = true)
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "active": true
}

### Search all templates including all versions (no criteria)
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{}

### Search by exact template key
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKey": "etl-data-processing",
    "version": "1.0.0"
}

### Search all versions of a specific template by templateKey
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKey": "etl-data-processing"
}

### Search for inactive templates
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "active": false
}

### Search by template key prefix
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKeyPrefix": "etl-"
}

### Search by description containing keyword
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "descriptionContains": "ETL"
}

### Get specific version of a template (search by key + version)
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKey": "etl-data-processing",
  "version": "1.0.0"
}

### Get active version of template (search by key + active=true)
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKey": "etl-data-processing",
  "active": true
}

###
# -----------------------------------------------------------------------------
# 4. Search templates with pagination
# -----------------------------------------------------------------------------
### Search all templates, first page with 10 items per page
POST {{baseUrl}}/api/v1/template/search/page?pageSize=10
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{}

### Search active templates, second page with 2 items per page
POST {{baseUrl}}/api/v1/template/search/page?page=3&pageSize=1
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "active": true
}

### Search ETL templates with pagination - first page, 5 items per page
POST {{baseUrl}}/api/v1/template/search/page?page=0&pageSize=5
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "descriptionContains": "ETL"
}

###
# -----------------------------------------------------------------------------
# 5. Update an existing template version
# -----------------------------------------------------------------------------
### Update ETL template v1.1.0 - activate it by update
PUT {{baseUrl}}/api/v1/template/etl-data-processing/v/1.1.0
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKey": "etl-data-processing",
  "templateName": "ETL Data Processing Workflow",
  "description": "A general-purpose ETL workflow with retry, error tolerance and atomic write support",
  "version": "1.1.0",
  "active": true,
  "dagDefinition": "{\n  \"nodes\": [\n    {\"id\": \"extract\", \"type\": \"extractor\", \"config\": {\"source\": \"${source}\", \"retryCount\": 3}},\n    {\"id\": \"transform\", \"type\": \"transformer\", \"config\": {\"rules\": \"${transformRules}\", \"errorTolerance\": 0.05}},\n    {\"id\": \"load\", \"type\": \"loader\", \"config\": {\"destination\": \"${destination}\", \"atomicWrite\": true}}\n  ],\n  \"edges\": [\n    {\"from\": \"extract\", \"to\": \"transform\"},\n    {\"from\": \"transform\", \"to\": \"load\"}\n  ]\n}",
  "parameterSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"source\": {\"type\": \"string\", \"description\": \"Source connection string\"},\n    \"transformRules\": {\"type\": \"string\", \"description\": \"Transformation rules JSON\"},\n    \"destination\": {\"type\": \"string\", \"description\": \"Destination connection string\"},\n    \"errorTolerance\": {\"type\": \"number\", \"description\": \"Allowed error rate 0.0-1.0\", \"default\": 0.0}\n  },\n  \"required\": [\"source\", \"destination\"]\n}"
}

###
# -----------------------------------------------------------------------------
# 6. Deactivate a template version
# -----------------------------------------------------------------------------
### Deactivate old ETL version 1.0.0
POST {{baseUrl}}/api/v1/template/etl-data-processing/v/1.0.0/deactivate
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

### Verify deactivation - search for inactive templates
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "active": false
}

###
# -----------------------------------------------------------------------------
# 7. Delete a template version
# -----------------------------------------------------------------------------
### Delete inactive version 1.0.0 (after deactivation)
DELETE {{baseUrl}}/api/v1/template/etl-data-processing/v/1.0.0
Authorization: Basic {{username}} {{password}}

### Verify deletion - search all versions of etl-data-processing
POST {{baseUrl}}/api/v1/template/search
Content-Type: application/json
Authorization: Basic {{username}} {{password}}

{
  "templateKey": "etl-data-processing"
}

###
# -----------------------------------------------------------------------------
# 8. Health check
# -----------------------------------------------------------------------------
### Get health info
GET {{baseUrl}}/actuator/health
Authorization: Basic {{username}} {{password}}
